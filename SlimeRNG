        local c_0x11lIII, c_0x1Ill1l = 0, 0
        local has3 = true
        local has4 = true
        local ch3 = d_0xIIllIl:sub(i_0xll1l1I+2,i_0xll1l1I+2)
        if ch3 == "=" then has3 = false else c_0x11lIII = b64_0x1Illll[ch3] or 0 end
        local ch4 = d_0xIIllIl:sub(i_0xll1l1I+3,i_0xll1l1I+3)
        if ch4 == "=" then has4 = false else c_0x1Ill1l = b64_0x1Illll[ch4] or 0 end
