        table.insert(r_0xI1IIII, string.char(b_0x1l1II1))
        if has3 then table.insert(r_0xI1IIII, string.char(b_0xl1llII)) end
        if has4 then table.insert(r_0xI1IIII, string.char(b_0xl1ll11)) end
