        local b_0xIlI1Il = math.floor(b_0xI1IlIl / (2^16)) % (2^8)
        local b_0xll1I1l = math.floor(b_0xI1IlIl / (2^8)) % (2^8)
        local b_0xI1I1ll = b_0xI1IlIl % (2^8)
        table.insert(r_0x1III1l, string.char(b_0xIlI1Il))
        if has3 then table.insert(r_0x1III1l, string.char(b_0xll1I1l)) end
        if has4 then table.insert(r_0x1III1l, string.char(b_0xI1I1ll)) end
    end
    return table.concat(r_0x1III1l)
end


local function bxor_0xIlllll(a_0xIIl1l1,b_0xIlIlll)
