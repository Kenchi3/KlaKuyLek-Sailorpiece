    local res_0xIIll1l = a_0x1lllIl
    while true do
        if st_0xlIIIll == 0 then
            res_0xIIll1l = res_0xIIll1l + 1
            st_0xlIIIll = 1
        elseif st_0xlIIIll == 1 then
            res_0xIIll1l = res_0xIIll1l * 2
            st_0xlIIIll = 2
        elseif st_0xlIIIll == 2 then
            res_0xIIll1l = res_0xIIll1l - 3
            st_0xlIIIll = 3
