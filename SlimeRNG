        if x_0xlIll1l ~= y_0xIllIII then r_0xlllllI = r_0xlllllI + (2^i_0x1IlIll) end
        a_0xIIl1l1 = math.floor(a_0xIIl1l1 / 2)
        b_0xIlIlll = math.floor(b_0xIlIlll / 2)
    end
